pipeline {
    agent any

    stages{
        stage('print Hostname'){
            steps{
                sh 'hostname'
            }
        }
        stage('ip address'){
            steps{
                sh 'hostname -I'
            }
            
        }
        stage('CPU details'){
            steps{
                sh 'lscpu'
            }
            
        }
        stage('Disk Usage'){
            steps{
                sh 'df -kh'
            }
        }
        stage('Memory usage'){
            steps{
                sh 'free -h'
            }
        }
    }
}
